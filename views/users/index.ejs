<body>
  <%- include('../partials/_navbar') %>
  <h1>Explore Our Community</h1>

  <% if (users.length > 0)  %>
  <ul>
    <% users.forEach(user =>  %>
    <li>
      <a href="/users/<%= user._id %>"><%= user.username %></a>
    </li>
    <% ) %>
  </ul>
  <%  else { %>
  <p>No users found.</p>
  <% } %>
</body>